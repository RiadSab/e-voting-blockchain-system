pragma solidity ^0.8.19;

import "forge-std/Test.sol";
import "../src/SchnorrVerifier.sol";

contract SchnorrVerifierTest is Test {
    SchnorrVerifier v;

    function setUp() public {
        v = new SchnorrVerifier();
    }

    function test_RealProofVerifies() public view {
        bool ok = v.verify(
            1, 2,  // g
            10415861484417082502655338383609494480414113902179649885744799961447382638712,
            10196215078179488638353184030336251401353352596818396260819493263908881608606, // u
            19825091793883686707627649340950405319014873082825026041280249854161651444241,
            4327884488611733017701728497650717852673535982247278853056504269735508252754,  // t
            3883374087358713062858613725551956042844969714763316889052093777747871721657   // z
        );
        assertTrue(ok);
    }

    function test_TamperedProofFails() public view {
        bool ok = v.verify(
            1, 2,
            10415861484417082502655338383609494480414113902179649885744799961447382638712,
            10196215078179488638353184030336251401353352596818396260819493263908881608606,
            19825091793883686707627649340950405319014873082825026041280249854161651444241,
            4327884488611733017701728497650717852673535982247278853056504269735508252754,
            3883374087358713062858613725551956042844969714763316889052093777747871721656  // z - 1, tampered
        );
        assertFalse(ok);
    }
}